# Copy this file to .env and fill in your own values. Never commit .env.

PORT=4000

# Jira Cloud settings (used by /api/jira routes)
# Base URL of your Jira site, no trailing slash
JIRA_BASE_URL=https://yourcompany.atlassian.net
# The email address tied to your Jira API token
JIRA_EMAIL=you@company.com
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# Comma-separated list of origins allowed to call this API (your frontend URL)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Powers the AI Assistant tool (explain / fix / format / generate tests).
# Get one at: https://console.anthropic.com

GROQ_API_KEY=your_groq_api_key_here

